import { useState, useEffect } from "react";
import Papa from "papaparse";

const EXCLUDE = ["취소", "수리제외"];

function parseDate(v) {
  if (!v) return null;
  let s = String(v).trim();
  s = s.replace(/(\d{4})년\s*(\d{1,2})월\s*(\d{1,2})일/, (_, y, m, d) =>
    `${y}-${m.padStart(2,"0")}-${d.padStart(2,"0")}`);
  const d = new Date(s);
  return isNaN(d) ? null : d;
}

function is2026(v) {
  const d = parseDate(v);
  return d && d.getFullYear() === 2026;
}

function getLatest2026Month(dates) {
  const parsed = dates.map(parseDate).filter(d => d && d.getFullYear() === 2026);
  if (!parsed.length) return null;
  return new Date(Math.max(...parsed.map(d => d.getTime())));
}

function inWeek(v, maxT) {
  const d = parseDate(v);
  return d && d.getFullYear() === 2026 && (maxT - d.getTime()) <= 7*24*60*60*1000;
}

function inMonth(v, latest) {
  const d = parseDate(v);
  return d && d.getFullYear() === 2026 && d.getMonth() === latest.getMonth();
}

function filterGajeon(rows, period, extra) {
  const dates = rows.map(r => r["접수일"]);
  const latest = getLatest2026Month(dates);
  const maxT = latest ? Math.max(...dates.map(v => { const d = parseDate(v); return d && d.getFullYear()===2026 ? d.getTime() : 0; })) : 0;

  return rows.filter(r => {
    if (!is2026(r["접수일"])) return false;
    if (period === "월간" && latest && !inMonth(r["접수일"], latest)) return false;
    if (period === "주간" && !inWeek(r["접수일"], maxT)) return false;
    if (EXCLUDE.includes(String(r["진행상황"]||"").trim())) return false;
    return extra ? extra(r) : true;
  });
}

function filterExt(rows, period) {
  const dates = rows.map(r => r["접수일자"]);
  const latest = getLatest2026Month(dates);
  const maxT = latest ? Math.max(...dates.map(v => { const d = parseDate(v); return d && d.getFullYear()===2026 ? d.getTime() : 0; })) : 0;
  return rows.filter(r => {
    if (!is2026(r["접수일자"])) return false;
    if (period === "월간" && latest && !inMonth(r["접수일자"], latest)) return false;
    if (period === "주간" && !inWeek(r["접수일자"], maxT)) return false;
    return true;
  });
}

function filterByPW(rows, period, pwCol) {
  return rows.filter(r => {
    const yr = Number(r["년"]||0);
    if (yr && yr < 2026) return false;
    const pw = String(r[pwCol]||"");
    if (period === "주간") return pw.includes("주");
    if (period === "월간") return pw.includes("월");
    return true;
  });
}

function groupCount(arr, key) {
  const m = {};
  arr.forEach(r => { const k = String(r[key]||"기타").trim(); if(k) m[k]=(m[k]||0)+1; });
  return Object.entries(m).sort((a,b)=>b[1]-a[1]).map(([l,v])=>({l,v}));
}

function groupSum(arr, keyGroup, keyVal) {
  const m = {};
  arr.forEach(r => { const k = String(r[keyGroup]||"기타").trim(); m[k]=(m[k]||0)+(Number(r[keyVal])||0); });
  return Object.entries(m).sort((a,b)=>b[1]-a[1]).map(([l,v])=>({l,v}));
}

function groupTagSum(arr, keyTag, keyVal) {
  const m = {};
  arr.forEach(r => { const k = String(r[keyTag]||"기타").trim(); m[k]=(m[k]||0)+(Number(r[keyVal])||0); });
  return Object.entries(m).sort((a,b)=>b[1]-a[1]).map(([l,v])=>({l,v}));
}

export default function App() {
  const [status, setStatus] = useState("idle");
  const [json, setJson] = useState(null);
  const [log, setLog] = useState([]);

  const addLog = m => setLog(p => [...p, m]);

  async function run() {
    setStatus("running");
    setLog([]);
    setJson(null);

    try {
      const files = ["가전마감.csv","가전외마감.csv","관여해결율.csv","만족도조사.csv","반품교환율.csv","반품현황.csv","상담태그.csv","인입태그.csv","통화성공율.csv"];
      const DB = {};
      for (const f of files) {
        const buf = await window.fs.readFile(f, { encoding:"utf8" });
        DB[f] = Papa.parse(buf, { header:true, skipEmptyLines:true, dynamicTyping:true }).data;
        addLog(`✅ ${f} (${DB[f].length}행)`);
      }

      const 가전 = DB["가전마감.csv"];
      const 가전외 = DB["가전외마감.csv"];
      const 반품현황r = DB["반품현황.csv"];
      const 반품교환율r = DB["반품교환율.csv"];
      const 상담태그r = DB["상담태그.csv"];
      const 인입태그r = DB["인입태그.csv"];
      const 통화성공율r = DB["통화성공율.csv"];
      const 관여해결율r = DB["관여해결율.csv"];
      const 만족도조사r = DB["만족도조사.csv"];

      const now = new Date();
      const updated = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,"0")}.${String(now.getDate()).padStart(2,"0")}`;

      const result = { updated, 상담실적:{}, 반품현황:{}, 처리현황:{}, 품질관리:{} };

      for (const period of ["주간","월간","연간"]) {
        addLog(`\n── ${period} 집계 중...`);

        // ── 상담실적 ──
        const 인입rows = filterByPW(인입태그r, period, "주/월");
        const 상담rows = filterByPW(상담태그r, period, "주/월");
        const 통화rows = filterByPW(통화성공율r, period, "주기");
        const 관여2026 = 관여해결율r.filter(r=>Number(r["년"]||0)===2026);
        const 만족2026 = 만족도조사r.filter(r=>{ const d=parseDate(r["마감일"]); return d&&d.getFullYear()===2026; });
        const 만족최신 = [...만족2026].sort((a,b)=>parseDate(b["마감일"])-parseDate(a["마감일"]))[0];
        const 관여최신 = [...관여2026].sort((a,b)=>b["관여건"]-a["관여건"])[0];

        result.상담실적[period] = {
          총인입수: 인입rows.reduce((s,r)=>s+(Number(r["인입수"])||0),0),
          총상담수: 상담rows.reduce((s,r)=>s+(Number(r["인입수"])||0),0),
          ALF관여건: 관여최신?.["관여건"] ?? null,
          만족도: 만족최신 ? Number(Number(만족최신["만족도"]).toFixed(2)) : null,
          만족도참여율: 만족최신?.["참여율"] ?? null,
          인입태그: groupTagSum(인입rows,"서비스태그","인입수"),
          상담태그: groupTagSum(상담rows,"상담태그","인입수"),
          통화성공율: 통화rows.map(r=>({ l:String(r["회차"]||r["마감일"]||""), v:parseFloat(String(r["통화 call"]||"0").replace(/[^0-9.]/g,""))||0 })),
          만족도추이: 만족2026.map(r=>({ l:String(r["월별"]||""), v:Number(r["만족도"])||0 })),
        };

        // ── 반품현황 ──
        const 반품f = r => {
          const yr = Number(String(r["마감회차"]||"").slice(0,4));
          if (yr && yr < 2026) return false;
          const pw = String(r["주/월"]||"");
          if (period==="주간") return pw.includes("주");
          if (period==="월간") return pw.includes("월");
          return true;
        };
        const 반품rows = 반품현황r.filter(반품f);
        const 꿈비 = 반품rows.filter(r=>String(r["구분"]||"").includes("꿈비"));
        const 소브 = 반품rows.filter(r=>String(r["구분"]||"").includes("소브"));
        const 율2026 = 반품교환율r.filter(r=>{ const yr=Number(String(r["마감월"]||"").slice(0,4)); return !yr||yr>=2026; });

        result.반품현황[period] = {
          꿈비총건: 꿈비.reduce((s,r)=>s+(Number(r["건수"])||0),0),
          소브총건: 소브.reduce((s,r)=>s+(Number(r["건수"])||0),0),
          꿈비교환율: 율2026.find(r=>String(r["구분"]||"").includes("꿈비"))?.[`반품/교환율`] ?? null,
          소브교환율: 율2026.find(r=>String(r["구분"]||"").includes("소브"))?.[`반품/교환율`] ?? null,
          꿈비유형: groupSum(꿈비,"교환/반품","건수"),
          소브유형: groupSum(소브,"교환/반품","건수"),
          꿈비사유: groupSum(꿈비,"사유","건수"),
          소브사유: groupSum(소브,"사유","건수"),
        };

        // ── 처리현황 ──
        const 수리rows = filterGajeon(가전, period, r=>["수리출고","점검"].includes(String(r["구분"]||"").trim()));
        const 무상 = 수리rows.filter(r=>String(r["유/무상"]||"").includes("무상")).length;
        const 유상 = 수리rows.filter(r=>String(r["유/무상"]||"").includes("유상")).length;
        const 유상금액 = 수리rows.filter(r=>String(r["유/무상"]||"").includes("유상")).reduce((s,r)=>s+(parseFloat(String(r["유상AS비용"]||"0").replace(/,/g,""))||0),0);
        const 자재rows = filterGajeon(가전, period, r=>String(r["구분"]||"").trim()==="자재출고");
        const 자재모델={}, 자재부품={};
        자재rows.forEach(r=>{
          const k=String(r["제품명"]||"기타"); 자재모델[k]=(자재모델[k]||0)+1;
          String(r["사용부품"]||"").split(",").forEach(p=>{ const pk=p.trim(); if(pk) 자재부품[pk]=(자재부품[pk]||0)+1; });
        });

        const 가전외rows = filterExt(가전외, period);
        const 가전외유상 = 가전외rows.filter(r=>String(r["유/무상"]||"").includes("유상"));
        const 가전외금액 = 가전외유상.reduce((s,r)=>s+(parseFloat(String(r["비용"]||"0").replace(/,/g,""))||0),0);
        const 가전외모델={};
        가전외rows.forEach(r=>{ const k=String(r["상품명"]||"기타"); 가전외모델[k]=(가전외모델[k]||0)+1; });
        const 소요평균 = 가전외rows.length ? Number((가전외rows.reduce((s,r)=>s+(Number(r["소요기간"])||0),0)/가전외rows.length).toFixed(1)) : null;

        result.처리현황[period] = {
          수리총건: 수리rows.length,
          무상, 유상,
          무상율: 수리rows.length ? Math.round(무상/수리rows.length*100) : 0,
          유상율: 수리rows.length ? Math.round(유상/수리rows.length*100) : 0,
          유상금액: Math.round(유상금액/10000),
          자재모델: Object.entries(자재모델).sort((a,b)=>b[1]-a[1]).map(([l,v])=>({l,v})),
          자재부품: Object.entries(자재부품).sort((a,b)=>b[1]-a[1]).slice(0,15).map(([l,v])=>({l,v})),
          가전외: {
            접수: 가전외rows.length,
            유상: 가전외유상.length,
            유상율: 가전외rows.length ? Math.round(가전외유상.length/가전외rows.length*100) : 0,
            금액: Math.round(가전외금액/10000),
            소요평균,
            모델: Object.entries(가전외모델).sort((a,b)=>b[1]-a[1]).map(([l,v])=>({l,v})),
          }
        };

        // ── 품질관리 ──
        const 품질rows = filterGajeon(가전, period, r=>["수리출고","자재출고","교환/환불"].includes(String(r["구분"]||"").trim()));
        const 불량집계={};
        품질rows.forEach(r=>{ const k=String(r["제품명"]||"기타").trim(); 불량집계[k]=(불량집계[k]||0)+1; });
        const top5 = Object.entries(불량집계).sort((a,b)=>b[1]-a[1]).slice(0,5);
        const 총불량 = Object.values(불량집계).reduce((a,b)=>a+b,0);
        const 불량접수집계={};
        품질rows.forEach(r=>{ String(r["접수불량"]||"").split(",").forEach(t=>{ const k=t.trim(); if(k) 불량접수집계[k]=(불량접수집계[k]||0)+1; }); });
        const 구분별 = ["수리출고","자재출고","교환/환불"].map(구분=>({
          l: 구분,
          v: filterGajeon(가전, period, r=>String(r["구분"]||"").trim()===구분).length
        }));

        result.품질관리[period] = {
          총불량,
          top5,
          구분별,
          접수불량top10: Object.entries(불량접수집계).sort((a,b)=>b[1]-a[1]).slice(0,10).map(([l,v])=>({l,v})),
        };

        addLog(`   상담: 인입 ${result.상담실적[period].총인입수}건`);
        addLog(`   반품: 꿈비 ${result.반품현황[period].꿈비총건}건 / 소브 ${result.소브총건}건`);
        addLog(`   처리: 수리 ${result.처리현황[period].수리총건}건`);
        addLog(`   품질: 불량 ${result.품질관리[period].총불량}건`);
      }

      const jsonStr = JSON.stringify(result, null, 2);
      setJson(jsonStr);
      setStatus("done");
      addLog("\n🎉 dashboard.json 생성 완료!");
    } catch(e) {
      setStatus("error");
      addLog("❌ 오류: " + e.message);
    }
  }

  function download() {
    const blob = new Blob([json], { type:"application/json" });
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "dashboard.json";
    a.click();
  }

  useEffect(() => { run(); }, []);

  return (
    <div style={{fontFamily:"sans-serif", padding:20, maxWidth:600}}>
      <h3 style={{marginBottom:12}}>CSV → dashboard.json 집계</h3>
      <div style={{background:"#1e1e2e", color:"#a6e3a1", borderRadius:8, padding:12, fontSize:12, fontFamily:"monospace", marginBottom:16, minHeight:200, maxHeight:400, overflowY:"auto"}}>
        {log.map((l,i)=><div key={i}>{l}</div>)}
      </div>
      {status==="done" && (
        <button onClick={download} style={{background:"#1e40af", color:"#fff", border:"none", borderRadius:8, padding:"12px 28px", fontSize:15, cursor:"pointer", fontWeight:700}}>
          dashboard.json 다운로드
        </button>
      )}
      {status==="error" && <div style={{color:"red"}}>오류가 발생했습니다.</div>}
    </div>
  );
}
