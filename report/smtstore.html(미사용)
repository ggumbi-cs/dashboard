<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>스마트스토어 분석</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:        #0d1117;
  --bg2:       #161b22;
  --bg3:       #1c2128;
  --border:    #30363d;
  --text:      #e6edf3;
  --text2:     #8b949e;
  --text3:     #484f58;
  --green:     #3fb950;
  --green2:    #0d4b25;
  --orange:    #f0883e;
  --orange2:   #4a2108;
  --red:       #f85149;
  --red2:      #4a1010;
  --blue:      #58a6ff;
  --blue2:     #0c2d6b;
  --purple:    #bc8cff;
  --yellow:    #e3b341;
  --naver:     #03C75A;

  --radius:    8px;
  --radius-lg: 12px;
  font-size: 14px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Noto Sans KR', sans-serif;
  font-weight: 400;
  min-height: 100vh;
}

/* ── 상단 헤더 ── */
.top-bar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  position: sticky;
  top: 0;
  z-index: 10;
}
.top-bar .logo {
  display: flex;
  align-items: center;
  gap: 8px;
}
.top-bar .logo svg { width: 20px; height: 20px; }
.top-bar h1 {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}
.top-bar .period-badge {
  margin-left: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--text2);
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 4px 10px;
  border-radius: 20px;
}
.top-bar .status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--text3);
  transition: background 0.3s;
}
.top-bar .status-dot.ok  { background: var(--green); box-shadow: 0 0 6px var(--green); }
.top-bar .status-dot.err { background: var(--red); }
.top-bar .status-dot.loading {
  background: var(--yellow);
  animation: pulse 1s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── 탭 ── */
.tab-bar {
  display: flex;
  gap: 2px;
  padding: 12px 20px 0;
  border-bottom: 1px solid var(--border);
  background: var(--bg2);
}
.tab-btn {
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text2);
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s;
  font-family: inherit;
  margin-bottom: -1px;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active {
  color: var(--blue);
  border-bottom-color: var(--blue);
}

/* ── 컨텐츠 ── */
.content {
  padding: 20px;
  max-width: 1200px;
}
.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* ── KPI 그리드 ── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 12px;
  margin-bottom: 20px;
}
.kpi-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 16px 18px;
  position: relative;
  overflow: hidden;
}
.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent, var(--blue));
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}
.kpi-card.green  { --accent: var(--green); }
.kpi-card.orange { --accent: var(--orange); }
.kpi-card.red    { --accent: var(--red); }
.kpi-card.purple { --accent: var(--purple); }
.kpi-card .kpi-label {
  font-size: 11px;
  color: var(--text2);
  font-weight: 500;
  letter-spacing: 0.03em;
  margin-bottom: 8px;
}
.kpi-card .kpi-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 28px;
  font-weight: 600;
  color: var(--text);
  line-height: 1;
}
.kpi-card .kpi-sub {
  font-size: 11px;
  color: var(--text2);
  margin-top: 6px;
}
.kpi-card .kpi-badge {
  display: inline-block;
  padding: 2px 7px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 600;
}
.badge-red    { background: var(--red2);    color: var(--red); }
.badge-green  { background: var(--green2);  color: var(--green); }
.badge-orange { background: var(--orange2); color: var(--orange); }
.badge-blue   { background: var(--blue2);   color: var(--blue); }

/* ── 섹션 ── */
.section {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: 16px;
  overflow: hidden;
}
.section-head {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-head h2 {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
}
.section-head .count-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 2px 8px;
  border-radius: 10px;
  color: var(--text2);
}
.section-head .ml-auto { margin-left: auto; }
.section-body { padding: 0; }

/* ── 필터 바 ── */
.filter-bar {
  display: flex;
  gap: 8px;
  padding: 12px 18px;
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
  align-items: center;
}
.filter-btn {
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 500;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text2);
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
}
.filter-btn:hover { border-color: var(--blue); color: var(--blue); }
.filter-btn.active { background: var(--blue2); border-color: var(--blue); color: var(--blue); }
.filter-input {
  padding: 5px 12px;
  font-size: 12px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text);
  font-family: inherit;
  outline: none;
  min-width: 200px;
}
.filter-input:focus { border-color: var(--blue); }

/* ── QnA 리스트 ── */
.qna-list { max-height: 520px; overflow-y: auto; }
.qna-item {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}
.qna-item:last-child { border-bottom: none; }
.qna-item:hover { background: var(--bg3); }
.qna-row1 {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 6px;
}
.qna-product {
  font-size: 11px;
  color: var(--text2);
  background: var(--bg3);
  border: 1px solid var(--border);
  padding: 2px 8px;
  border-radius: 4px;
  white-space: nowrap;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
}
.qna-status {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 4px;
}
.qna-status.answered   { background: var(--green2);  color: var(--green); }
.qna-status.unanswered { background: var(--orange2); color: var(--orange); }
.qna-date {
  margin-left: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text3);
  white-space: nowrap;
}
.qna-content {
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
  word-break: break-all;
}
.qna-answer {
  margin-top: 8px;
  padding: 8px 12px;
  background: var(--bg3);
  border-left: 3px solid var(--naver);
  border-radius: 0 4px 4px 0;
  font-size: 12px;
  color: var(--text2);
  line-height: 1.5;
}
.qna-answer .ans-label {
  font-size: 10px;
  font-weight: 600;
  color: var(--naver);
  margin-bottom: 4px;
}
.new-tag {
  font-size: 10px;
  font-weight: 700;
  background: #2d1b00;
  color: var(--yellow);
  border: 1px solid var(--yellow);
  padding: 1px 6px;
  border-radius: 4px;
}

/* ── 주문 테이블 ── */
.order-table-wrap { overflow-x: auto; max-height: 480px; overflow-y: auto; }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
thead th {
  position: sticky;
  top: 0;
  background: var(--bg3);
  border-bottom: 1px solid var(--border);
  padding: 9px 12px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  color: var(--text2);
  white-space: nowrap;
  z-index: 1;
}
tbody td {
  padding: 9px 12px;
  border-bottom: 1px solid var(--border);
  color: var(--text);
  vertical-align: middle;
}
tbody tr:hover td { background: var(--bg3); }
tbody tr:last-child td { border-bottom: none; }
.mono { font-family: 'JetBrains Mono', monospace; }

/* ── 상태 칩 ── */
.status-chip {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 600;
  white-space: nowrap;
}
.chip-pay    { background: #1a2e50; color: var(--blue); }
.chip-depart { background: var(--green2); color: var(--green); }
.chip-deliv  { background: #1a2e50; color: #79c0ff; }
.chip-done   { background: #1c2128; color: var(--text2); }
.chip-cancel { background: var(--red2); color: var(--red); }
.chip-return { background: var(--orange2); color: var(--orange); }
.chip-other  { background: var(--bg3); color: var(--text3); }

/* ── 상태 분포 바 ── */
.status-bar-wrap { padding: 16px 18px; }
.status-bar-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.status-bar-label { width: 100px; font-size: 12px; color: var(--text2); flex-shrink: 0; }
.status-bar-track {
  flex: 1;
  height: 8px;
  background: var(--bg3);
  border-radius: 4px;
  overflow: hidden;
}
.status-bar-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.6s ease;
}
.status-bar-cnt {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--text2);
  width: 40px;
  text-align: right;
  flex-shrink: 0;
}

/* ── 제품 그리드 ── */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
  padding: 16px 18px;
}
.product-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
  font-size: 12px;
}
.product-card .pname {
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6px;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-card .pmeta {
  color: var(--text2);
  font-size: 11px;
  line-height: 1.8;
}
.product-card .pstatus {
  margin-top: 8px;
}

/* ── 로딩 / 빈 상태 ── */
.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  color: var(--text3);
  gap: 10px;
  font-size: 13px;
}
.placeholder svg { opacity: 0.3; }
.spinner {
  width: 28px; height: 28px;
  border: 3px solid var(--border);
  border-top-color: var(--blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── 에러 배너 ── */
.err-banner {
  background: var(--red2);
  border: 1px solid var(--red);
  border-radius: var(--radius);
  padding: 12px 16px;
  font-size: 13px;
  color: var(--red);
  margin-bottom: 16px;
}

/* ── 스크롤바 ── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text3); }
</style>
</head>
<body>

<!--
  ================================================================
  report/smtstore.html  ─  스마트스토어 분석 대시보드
  index.html TAB_MAP 추가 필요:
    '스마트스토어': 'report/smtstore.html'
  ================================================================
-->

<!-- 상단 바 -->
<div class="top-bar">
  <div class="logo">
    <svg viewBox="0 0 20 20" fill="none">
      <rect width="20" height="20" rx="4" fill="#03C75A"/>
      <path d="M4 10h12M10 4v12" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
    </svg>
    <h1>스마트스토어 분석</h1>
  </div>
  <span id="periodBadge" class="period-badge">─</span>
  <span id="statusDot" class="status-dot"></span>
</div>

<!-- 탭 -->
<div class="tab-bar">
  <button class="tab-btn active" data-tab="overview">개요</button>
  <button class="tab-btn" data-tab="qna">문의 <span id="qnaBadge" class="count-badge" style="display:none"></span></button>
  <button class="tab-btn" data-tab="orders">주문</button>
  <button class="tab-btn" data-tab="products">상품</button>
</div>

<div class="content">

  <!-- ═══ 탭: 개요 ═══ -->
  <div class="tab-panel active" id="panel-overview">
    <div class="kpi-grid" id="kpiGrid">
      <div class="placeholder" style="grid-column:1/-1">
        <div class="spinner"></div>
        <span>데이터 불러오는 중…</span>
      </div>
    </div>

    <!-- 주문 상태 분포 -->
    <div class="section" id="overviewOrderSection" style="display:none">
      <div class="section-head">
        <h2>주문 상태 분포</h2>
        <span id="overviewOrderTotal" class="count-badge">0건</span>
      </div>
      <div class="status-bar-wrap" id="overviewStatusBars"></div>
    </div>

    <!-- 미답변 문의 미리보기 -->
    <div class="section" id="overviewQnaSection" style="display:none">
      <div class="section-head">
        <h2>미답변 문의</h2>
        <span id="overviewQnaCount" class="count-badge">0건</span>
        <button class="filter-btn ml-auto" onclick="switchTab('qna')">전체 보기 →</button>
      </div>
      <div class="qna-list" id="overviewQnaList"></div>
    </div>

    <!-- 신제품 관련 문의 미리보기 -->
    <div class="section" id="overviewNewSection" style="display:none">
      <div class="section-head">
        <h2>신제품 관련 문의</h2>
        <span id="overviewNewCount" class="count-badge">0건</span>
        <button class="filter-btn ml-auto" onclick="switchTab('qna'); setTimeout(()=>applyQnaFilter('new'),100)">전체 보기 →</button>
      </div>
      <div class="qna-list" id="overviewNewList"></div>
    </div>

    <div id="overviewError" class="err-banner" style="display:none"></div>
  </div>

  <!-- ═══ 탭: 문의 ═══ -->
  <div class="tab-panel" id="panel-qna">
    <div class="section">
      <div class="section-head">
        <h2>상품 문의</h2>
        <span id="qnaTotalBadge" class="count-badge">0건</span>
      </div>
      <div class="filter-bar">
        <button class="filter-btn active" data-qna-filter="all" onclick="applyQnaFilter('all')">전체</button>
        <button class="filter-btn" data-qna-filter="unanswered" onclick="applyQnaFilter('unanswered')">미답변</button>
        <button class="filter-btn" data-qna-filter="answered" onclick="applyQnaFilter('answered')">답변완료</button>
        <button class="filter-btn" data-qna-filter="new" onclick="applyQnaFilter('new')">🌱 신제품 관련</button>
        <input class="filter-input" id="qnaSearch" type="text" placeholder="문의 내용 검색…" oninput="renderQnaList()">
      </div>
      <div class="qna-list" id="qnaList">
        <div class="placeholder">
          <div class="spinner"></div>
          <span>문의 데이터 불러오는 중…</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ 탭: 주문 ═══ -->
  <div class="tab-panel" id="panel-orders">
    <div class="section">
      <div class="section-head">
        <h2>주문 현황</h2>
        <span id="orderTotalBadge" class="count-badge">0건</span>
      </div>
      <div class="filter-bar">
        <button class="filter-btn active" data-order-filter="all" onclick="applyOrderFilter('all')">전체</button>
        <button class="filter-btn" data-order-filter="PAYMENT_WAITING" onclick="applyOrderFilter('PAYMENT_WAITING')">결제대기</button>
        <button class="filter-btn" data-order-filter="PAYED" onclick="applyOrderFilter('PAYED')">결제완료</button>
        <button class="filter-btn" data-order-filter="DELIVERING" onclick="applyOrderFilter('DELIVERING')">배송중</button>
        <button class="filter-btn" data-order-filter="DELIVERED" onclick="applyOrderFilter('DELIVERED')">배송완료</button>
        <button class="filter-btn" data-order-filter="CANCEL" onclick="applyOrderFilter('CANCEL')">취소/반품</button>
      </div>
      <div class="order-table-wrap">
        <table id="orderTable">
          <thead>
            <tr>
              <th>주문번호</th>
              <th>상품명</th>
              <th>수량</th>
              <th>결제금액</th>
              <th>수령인</th>
              <th>상태</th>
              <th>주문일시</th>
            </tr>
          </thead>
          <tbody id="orderTbody">
            <tr><td colspan="7">
              <div class="placeholder">
                <div class="spinner"></div>
                <span>주문 데이터 불러오는 중…</span>
              </div>
            </td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ═══ 탭: 상품 ═══ -->
  <div class="tab-panel" id="panel-products">
    <div class="section">
      <div class="section-head">
        <h2>상품 목록</h2>
        <span id="productTotalBadge" class="count-badge">0건</span>
        <div class="ml-auto" style="display:flex;gap:8px;align-items:center">
          <input class="filter-input" id="productSearch" type="text" placeholder="상품명 검색…" style="min-width:160px" oninput="renderProducts()">
        </div>
      </div>
      <div class="product-grid" id="productGrid">
        <div class="placeholder" style="grid-column:1/-1">
          <div class="spinner"></div>
          <span>상품 데이터 불러오는 중…</span>
        </div>
      </div>
    </div>
  </div>

</div><!-- /content -->

<script>
// ================================================================
// ★ 상태
// ================================================================
const STATE = {
  type:      '', period: '',
  startDate: null, endDate: null,
  scriptUrl: '', userRole: '',
  // 데이터
  qnas:      [], qnaFilter: 'all',
  orders:    [], orderFilter: 'all', statusMap: {},
  products:  [],
};

const ROLE_LEVEL = { admin:0, leader:1, ggumbi:2, affiliate:3 };
function hasRole(r) { return (ROLE_LEVEL[STATE.userRole]??99) <= (ROLE_LEVEL[r]??99); }

const NEW_KEYWORDS = ['신제품','새로','출시','언제','출시예정','사전예약','신상','언제나와'];

// ================================================================
// ★ URL 파라미터 파싱
// ================================================================
function initFromURL() {
  const params = new URLSearchParams(location.search);
  STATE.type   = params.get('type')   || '';
  STATE.period = params.get('period') || '';

  let startDate, endDate, label;
  const type = STATE.type, period = STATE.period;

  if (type === 'monthly' && period) {
    const yy = period.slice(0,2), mm = period.slice(3,5);
    const year = 2000 + parseInt(yy), month = parseInt(mm) - 1;
    startDate = new Date(year, month, 1);
    endDate   = new Date(year, month+1, 0);
    label     = `${year}년 ${parseInt(mm)}월`;
  } else if (type === 'weekly' && period.length === 6) {
    const friday  = new Date(`20${period.slice(0,2)}-${period.slice(2,4)}-${period.slice(4,6)}T00:00:00+09:00`);
    const saturday = new Date(friday); saturday.setDate(friday.getDate() - 6);
    startDate = saturday; endDate = friday;
    label = `주간 ${fmtDisp(saturday)} ~ ${fmtDisp(friday)}`;
  } else if (type === 'yearly' && period) {
    const year = parseInt(period);
    startDate = new Date(year, 0, 1); endDate = new Date(year, 11, 31);
    label = `${year}년 연간`;
  } else {
    // 파라미터 없으면 이번 달 기본
    const now = new Date();
    startDate = new Date(now.getFullYear(), now.getMonth(), 1);
    endDate   = new Date(now.getFullYear(), now.getMonth()+1, 0);
    label = `${now.getFullYear()}년 ${now.getMonth()+1}월`;
  }

  STATE.startDate = startDate;
  STATE.endDate   = endDate;
  document.getElementById('periodBadge').textContent = label;
}

function fmtDate(d) {
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
}
function fmtDisp(d) { return `${d.getMonth()+1}/${d.getDate()}`; }
function pad(n) { return String(n).padStart(2,'0'); }
function fmtDateTime(str) {
  if (!str) return '─';
  const d = new Date(str);
  if (isNaN(d)) return str;
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}
function numFmt(n) { return Number(n||0).toLocaleString(); }

