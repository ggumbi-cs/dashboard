// ★ postMessage 수신
// ================================================================
window.addEventListener('message', e => {
  if (!e.data) return;
  if (e.data.type === 'SCRIPT_URL') {
    STATE.scriptUrl = e.data.url      || '';
    STATE.userRole  = e.data.userRole || '';
