// ================================================================
// ★ GAS 호출
// ================================================================
async function gasGet(params) {
  const url = STATE.scriptUrl + '?' + new URLSearchParams(params).toString();
  const res  = await fetch(url);
  if (!res.ok) throw new Error('HTTP ' + res.status);
  return res.json();
}

// ================================================================
// ★ 전체 로드
// ================================================================
async function loadAll() {
  if (!STATE.scriptUrl) return;
  setStatus('loading');
  try {
    const sd = fmtDate(STATE.startDate);
    const ed = fmtDate(STATE.endDate);

    // 병렬 호출
    const [qnaRes, orderRes, productRes] = await Promise.all([
      gasGet({ action:'smtstore', sub:'qna',      startDate:sd, endDate:ed, pageSize:200 }),
      gasGet({ action:'smtstore', sub:'orders',   startDate:sd, endDate:ed }),
      gasGet({ action:'smtstore', sub:'products' }),
    ]);

    if (qnaRes.ok) {
      STATE.qnas = qnaRes.qnas || [];
      renderKpi(qnaRes, orderRes);
      renderOverviewQna(qnaRes);
      renderQnaList();
      // 탭 뱃지
      const ub = document.getElementById('qnaBadge');
      if (qnaRes.unanswered > 0) {
        ub.textContent = '미답변 ' + qnaRes.unanswered;
        ub.style.display = '';
        ub.style.background = '#4a2108';
        ub.style.color = '#f0883e';
      }
    }

    if (orderRes.ok) {
      STATE.orders    = orderRes.orders    || [];
      STATE.statusMap = orderRes.statusMap || {};
      renderOverviewOrders(orderRes);
      renderOrderTable();
    }

    if (productRes.ok) {
      STATE.products = productRes.products || [];
      renderProducts();
    }

    setStatus('ok');
  } catch(err) {
    setStatus('err');
    document.getElementById('overviewError').textContent = '데이터 로드 실패: ' + err.message;
    document.getElementById('overviewError').style.display = '';
  }
}

function setStatus(s) {
  const dot = document.getElementById('statusDot');
  dot.className = 'status-dot ' + s;
}

// ================================================================
// ★ KPI 카드
// ================================================================
function renderKpi(qna, order) {
  const grid = document.getElementById('kpiGrid');
  const qnaUn = qna.unanswered || 0;
  const qnaNew = qna.newRelated || 0;
  const orderTotal = order.total || 0;

  // 주문 상태별
  const sm = order.statusMap || {};
  const cancelCount = Object.entries(sm)
    .filter(([k]) => /CANCEL|RETURN|EXCHANGE/i.test(k))
    .reduce((s,[,v]) => s + v, 0);

  grid.innerHTML = `
    <div class="kpi-card">
      <div class="kpi-label">전체 문의</div>
      <div class="kpi-value">${numFmt(qna.total || 0)}</div>
      <div class="kpi-sub">조회 기간 합계</div>
    </div>
    <div class="kpi-card orange">
      <div class="kpi-label">미답변</div>
      <div class="kpi-value">${numFmt(qnaUn)}</div>
      <div class="kpi-sub">${qnaUn > 0 ? '<span class="kpi-badge badge-orange">답변 필요</span>' : '<span class="kpi-badge badge-green">없음</span>'}</div>
    </div>
    <div class="kpi-card purple">
      <div class="kpi-label">신제품 관련 문의</div>
      <div class="kpi-value">${numFmt(qnaNew)}</div>
      <div class="kpi-sub">키워드 감지</div>
    </div>
    <div class="kpi-card green">
      <div class="kpi-label">주문 건수</div>
      <div class="kpi-value">${numFmt(orderTotal)}</div>
      <div class="kpi-sub">기간 내 변경</div>
    </div>
    <div class="kpi-card red">
      <div class="kpi-label">취소/반품</div>
      <div class="kpi-value">${numFmt(cancelCount)}</div>
      <div class="kpi-sub">${orderTotal > 0 ? Math.round(cancelCount/orderTotal*100) + '%' : '─'}</div>
    </div>
  `;
}

// ================================================================
// ★ 개요 - 주문 상태 바
// ================================================================
const STATUS_META = {
  PAYMENT_WAITING:  { label:'결제대기',  color:'#58a6ff' },
  PAYED:            { label:'결제완료',  color:'#3fb950' },
  DISPATCHED:       { label:'발송완료',  color:'#79c0ff' },
  DELIVERING:       { label:'배송중',    color:'#a5d6ff' },
  DELIVERED:        { label:'배송완료',  color:'#56d364' },
  PURCHASE_DECIDED: { label:'구매확정',  color:'#8b949e' },
  CANCEL_DONE:      { label:'취소완료',  color:'#f85149' },
  RETURN_DONE:      { label:'반품완료',  color:'#f0883e' },
  EXCHANGE_DONE:    { label:'교환완료',  color:'#e3b341' },
};
function statusLabel(k) { return STATUS_META[k]?.label || k; }
function statusColor(k) { return STATUS_META[k]?.color || '#484f58'; }

function renderOverviewOrders(res) {
  const sec = document.getElementById('overviewOrderSection');
  const sm  = res.statusMap || {};
  const total = res.total || 0;
  if (total === 0) return;
  sec.style.display = '';
  document.getElementById('overviewOrderTotal').textContent = numFmt(total) + '건';

  const bars = document.getElementById('overviewStatusBars');
  const sorted = Object.entries(sm).sort(([,a],[,b]) => b - a);
  const max = sorted[0]?.[1] || 1;
  bars.innerHTML = sorted.map(([k, cnt]) => `
    <div class="status-bar-row">
      <div class="status-bar-label">${statusLabel(k)}</div>
      <div class="status-bar-track">
        <div class="status-bar-fill" style="width:${cnt/max*100}%;background:${statusColor(k)}"></div>
      </div>
      <div class="status-bar-cnt">${numFmt(cnt)}</div>
    </div>
  `).join('');
}

// ================================================================
// ★ 개요 - 문의 미리보기
// ================================================================
function renderOverviewQna(res) {
  const unList = res.unansweredList || [];
  const newList = res.newRelatedList || [];

  if (unList.length > 0) {
    document.getElementById('overviewQnaSection').style.display = '';
    document.getElementById('overviewQnaCount').textContent = numFmt(res.unanswered) + '건';
    document.getElementById('overviewQnaList').innerHTML = unList.slice(0,5).map(q => qnaItemHTML(q)).join('');
  }
  if (newList.length > 0) {
    document.getElementById('overviewNewSection').style.display = '';
    document.getElementById('overviewNewCount').textContent = numFmt(res.newRelated) + '건';
    document.getElementById('overviewNewList').innerHTML = newList.slice(0,5).map(q => qnaItemHTML(q)).join('');
  }
}

// ================================================================
// ★ 문의 탭
// ================================================================
function applyQnaFilter(f) {
  STATE.qnaFilter = f;
  document.querySelectorAll('[data-qna-filter]').forEach(b => {
    b.classList.toggle('active', b.dataset.qnaFilter === f);
  });
  renderQnaList();
}

function renderQnaList() {
  const kw = (document.getElementById('qnaSearch')?.value || '').toLowerCase();
  let list = STATE.qnas;

  if (STATE.qnaFilter === 'unanswered') list = list.filter(q => !q.answered && q.answerContent == null);
  if (STATE.qnaFilter === 'answered')   list = list.filter(q => q.answered  || q.answerContent);
  if (STATE.qnaFilter === 'new')        list = list.filter(q => isNewRelated(q));
  if (kw) list = list.filter(q => ((q.questionContent||'') + (q.productName||'')).toLowerCase().includes(kw));

  document.getElementById('qnaTotalBadge').textContent = numFmt(list.length) + '건';

  const el = document.getElementById('qnaList');
  if (list.length === 0) {
    el.innerHTML = '<div class="placeholder"><svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="currentColor" stroke-width="1.5"/></svg><span>해당하는 문의가 없습니다</span></div>';
    return;
  }
  el.innerHTML = list.map(q => qnaItemHTML(q)).join('');
}

function isNewRelated(q) {
  const t = ((q.questionContent||'') + (q.productName||'')).toLowerCase();
  return NEW_KEYWORDS.some(k => t.includes(k));
}

function qnaItemHTML(q) {
  const answered = q.answered || !!q.answerContent;
  const isNew    = isNewRelated(q);
  const date     = fmtDateTime(q.createdDate || q.createdAt || q.questionCreatedDate);
  const product  = q.productName || q.channelProductName || '상품명 없음';
  const content  = (q.questionContent || q.content || '내용 없음').slice(0, 200);
  const answer   = q.answerContent || '';

  return `
    <div class="qna-item">
      <div class="qna-row1">
        <span class="qna-product" title="${product}">${product}</span>
        <span class="qna-status ${answered ? 'answered' : 'unanswered'}">${answered ? '답변완료' : '미답변'}</span>
        ${isNew ? '<span class="new-tag">🌱 신제품</span>' : ''}
        <span class="qna-date">${date}</span>
      </div>
      <div class="qna-content">${escHtml(content)}</div>
      ${answer ? `<div class="qna-answer"><div class="ans-label">판매자 답변</div>${escHtml(answer.slice(0,200))}</div>` : ''}
    </div>
  `;
}

// ================================================================
// ★ 주문 탭
// ================================================================
function applyOrderFilter(f) {
  STATE.orderFilter = f;
  document.querySelectorAll('[data-order-filter]').forEach(b => {
    b.classList.toggle('active', b.dataset.orderFilter === f);
  });
  renderOrderTable();
}

function orderStatusChip(s) {
  const map = {
    PAYMENT_WAITING:  ['결제대기',  'chip-pay'],
    PAYED:            ['결제완료',  'chip-pay'],
    DISPATCHED:       ['발송완료',  'chip-depart'],
    DELIVERING:       ['배송중',    'chip-deliv'],
    DELIVERED:        ['배송완료',  'chip-deliv'],
    PURCHASE_DECIDED: ['구매확정',  'chip-done'],
    CANCEL_DONE:      ['취소완료',  'chip-cancel'],
    CANCEL_NOPAY:     ['미결제취소','chip-cancel'],
    RETURN_DONE:      ['반품완료',  'chip-return'],
    EXCHANGE_DONE:    ['교환완료',  'chip-return'],
  };
  const [label, cls] = map[s] || [s || '─', 'chip-other'];
  return `<span class="status-chip ${cls}">${label}</span>`;
}

function renderOrderTable() {
  let list = STATE.orders;
  if (STATE.orderFilter !== 'all') {
    list = list.filter(o => {
      const s = (o.productOrderStatus || o.lastChangedStatus || '').toUpperCase();
      if (STATE.orderFilter === 'CANCEL') return /CANCEL|RETURN|EXCHANGE/.test(s);
      return s === STATE.orderFilter;
    });
  }

  document.getElementById('orderTotalBadge').textContent = numFmt(list.length) + '건';

  const tbody = document.getElementById('orderTbody');
  if (list.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7"><div class="placeholder">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <span>해당하는 주문이 없습니다</span></div></td></tr>`;
    return;
  }

  tbody.innerHTML = list.map(o => {
    const orderInfo   = o.order || o;
    const productOrder = o.productOrder || o;
    const orderId     = productOrder.productOrderId || orderInfo.orderId || '─';
    const productName = productOrder.productName  || orderInfo.productName || '─';
    const qty         = productOrder.quantity     || 1;
    const price       = numFmt(productOrder.totalPaymentAmount || productOrder.unitPrice || 0);
    const buyer       = (orderInfo.order && orderInfo.order.ordererName) || orderInfo.ordererName || '─';
    const status      = productOrder.productOrderStatus || orderInfo.productOrderStatus || '─';
    const createdAt   = fmtDateTime(productOrder.paymentDate || orderInfo.paymentDate || orderInfo.createdAt);

    return `<tr>
      <td class="mono" style="font-size:11px">${orderId}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${productName}">${productName}</td>
      <td class="mono" style="text-align:right">${qty}</td>
      <td class="mono" style="text-align:right">${price}원</td>
      <td>${buyer}</td>
      <td>${orderStatusChip(status)}</td>
      <td class="mono" style="font-size:11px;color:var(--text2)">${createdAt}</td>
    </tr>`;
  }).join('');
}

// ================================================================
// ★ 상품 탭
// ================================================================
function renderProducts() {
  const kw  = (document.getElementById('productSearch')?.value || '').toLowerCase();
  let list  = STATE.products;
  if (kw) list = list.filter(p => (p.originProductNo ? String(p.originProductNo) : '')
    .toLowerCase().includes(kw) || (p.name||'').toLowerCase().includes(kw));

  document.getElementById('productTotalBadge').textContent = numFmt(list.length) + '건';
  const grid = document.getElementById('productGrid');

  if (list.length === 0) {
    grid.innerHTML = `<div class="placeholder" style="grid-column:1/-1">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="1.5"/></svg>
      <span>상품 데이터가 없습니다</span></div>`;
    return;
  }

  grid.innerHTML = list.map(p => {
    const name   = p.name || p.channelProductName || p.originProductNo || '─';
    const price  = numFmt(p.salePrice || p.price || 0);
    const status = p.statusType || p.saleStatusType || '─';
    const no     = p.originProductNo || '─';
    return `<div class="product-card">
      <div class="pname" title="${name}">${name}</div>
      <div class="pmeta">
        <div>번호: <span class="mono">${no}</span></div>
        <div>판매가: <strong>${price}원</strong></div>
        <div>상태: ${status}</div>
      </div>
    </div>`;
  }).join('');
}

// ================================================================
// ★ 유틸
// ================================================================
function escHtml(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

